# ─────────────────────────────────────────────────────────────
#  WELADTI  — Environment Variables Template
#  Copy this file to .env and fill in your actual values
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./weladti.db

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=weladti-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── Google Gemini AI ─────────────────────────────────────────
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── App Settings ─────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Flutter Backend URL (used in app) ────────────────────────
# For iOS Simulator on same Mac, use:
FLUTTER_BACKEND_URL=http://localhost:8000
